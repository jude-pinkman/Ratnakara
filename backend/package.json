{
  "name": "marine-backend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/app.ts",
    "build": "tsc",
    "start": "node dist/app.js",
    "db:init": "tsx src/data/initDatabase.ts",
    "seed": "tsx src/data/seed.ts",
    "seed:real": "tsx src/data/seedRealData.ts",
    "import:all": "tsx src/data/importers/index.ts",
    "import:full": "tsx src/data/importers/index.ts --importers worms,fao,noaa,json,dna,otolith",
    "import:worms": "tsx src/data/importers/index.ts --importers worms",
    "import:fao": "tsx src/data/importers/index.ts --importers fao",
    "import:noaa": "tsx src/data/importers/index.ts --importers noaa",
    "import:json": "tsx src/data/importers/index.ts --importers json",
    "import:dna": "tsx src/data/importers/index.ts --importers dna",
    "import:otolith": "tsx src/data/importers/index.ts --importers otolith",
    "import:reset": "tsx src/data/importers/index.ts --reset",
    "import:validate": "tsx src/data/importers/index.ts --dry-run",
    "import:help": "tsx src/data/importers/index.ts --help"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "csv-parse": "^5.6.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.11.3",
    "uuid": "^9.0.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.10.5",
    "@types/pg": "^8.10.9",
    "@types/uuid": "^9.0.7",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
