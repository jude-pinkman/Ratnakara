# Preferred for Neon or any managed Postgres
DATABASE_URL=

# Optional fallback for local Postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=marine_data
DB_USER=postgres
DB_PASSWORD=postgres
PORT=3001

# Data Import Configuration
FAO_CSV_PATH=backend/data/samples/fao_sample.csv
NOAA_CSV_PATH=backend/data/samples/noaa_sample.csv
WORMS_API_BASE=https://www.marinespecies.org/rest
IMPORT_BATCH_SIZE=1000
IMPORT_LOG_INTERVAL=100

# Optional: Strict taxonomy validation (if false, allows species not in taxonomy)
# STRICT_TAXONOMY=false

# Optional: Verbose logging for debugging
# VERBOSE=true
