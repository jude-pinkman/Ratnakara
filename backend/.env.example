# Backend API Configuration

# Server
PORT=3001
NODE_ENV=development

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/marine_data
# Example Neon URL:
# DATABASE_URL=postgresql://user:password@your-neon-host/neondb?sslmode=require&channel_binding=require
# OR use separate variables:
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=marine_data
# DB_USER=postgres
# DB_PASSWORD=postgres
