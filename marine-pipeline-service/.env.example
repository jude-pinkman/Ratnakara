# Marine Pipeline Service Configuration

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/marine_data

# Application
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8090
LOG_LEVEL=INFO

# Scheduler
SCHEDULER_ENABLED=true
SCHEDULER_OCEAN_JOB_MINUTES=60

# NOAA NDBC Stations (format: station_id:lat:lon)
NDBC_STATION_LIST=41037:27.5:-75.0,41001:34.7:-72.7,46050:44.7:-124.5

# API URLs
GBIF_BASE_URL=https://api.gbif.org/v1
NOAA_BASE_URL=https://www.ndbc.noaa.gov/data/realtime2
